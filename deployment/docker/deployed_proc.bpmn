                                |       </bpmn:extensionElements>                                                                                                                                                                                                                                                                                                                                                                                                                                              +
                                |     </bpmn:sequenceFlow>                                                                                                                                                                                                                                                                                                                                                                                                                                                     +
                                |     <bpmn:scriptTask id="Task_BuildFHIRPayload" name="Build FHIR Patient Payload" scriptFormat="javascript">                                                                                                                                                                                                                                                                                                                                                                 +
                                |       <bpmn:incoming>Flow_Gateway_To_BuildPayload</bpmn:incoming>                                                                                                                                                                                                                                                                                                                                                                                                            +
                                |       <bpmn:outgoing>Flow_BuildPayload_To_WriteEpic</bpmn:outgoing>                                                                                                                                                                                                                                                                                                                                                                                                          +
                                |       <bpmn:script>                                                                                                                                                                                                                                                                                                                                                                                                                                                          +
                                |         function getVar(name) {                                                                                                                                                                                                                                                                                                                                                                                                                                              +
                                |           try {                                                                                                                                                                                                                                                                                                                                                                                                                                                              +
                                |             var val = execution.getVariable(name);                                                                                                                                                                                                                                                                                                                                                                                                                           +
                                |             return (val !== null &amp;&amp; val !== undefined) ? String(val) : '';                                                                                                                                                                                                                                                                                                                                                                                           +
                                |           } catch (e) {                                                                                                                                                                                                                                                                                                                                                                                                                                                      +
                                |             return '';                                                                                                                                                                                                                                                                                                                                                                                                                                                       +
                                |           }                                                                                                                                                                                                                                                                                                                                                                                                                                                                  +
                                |         }                                                                                                                                                                                                                                                                                                                                                                                                                                                                    +
                                |                                                                                                                                                                                                                                                                                                                                                                                                                                                                              +
                                |         // Validate required fields at workflow level                                                                                                                                                                                                                                                                                                                                                                                                                        +
                                |         var firstName = getVar('firstName');                                                                                                                                                                                                                                                                                                                                                                                                                                 +
                                |         var lastName = getVar('lastName');                                                                                                                                                                                                                                                                                                                                                                                                                                   +
                                |         var dob = getVar('dateOfBirth');                                                                                                                                                                                                                                                                                                                                                                                                                                     +
                                |         var email = getVar('email');                                                                                                                                                                                                                                                                                                                                                                                                                                         +
                                |         var phone = getVar('phoneNumber');                                                                                                                                                                                                                                                                                                                                                                                                                                   +
                                |         var addr1 = getVar('addressLine1');                                                                                                                                                                                                                                                                                                                                                                                                                                  +
                                |         var city = getVar('city');                                                                                                                                                                                                                                                                                                                                                                                                                                           +
                                |         var state = getVar('state');                                                                                                                                                                                                                                                                                                                                                                                                                                         +
                                |         var pin = getVar('pincode');                                                                                                                                                                                                                                                                                                                                                                                                                                         +
                                |                                                                                                                                                                                                                                                                                                                                                                                                                                                                              +
                                |         if (!firstName || !lastName || !dob || !email || !phone || !addr1 || !city || !state || !pin) {                                                                                                                                                                                                                                                                                                                                                                      +
                                |           throw new org.camunda.bpm.engine.delegate.BpmnError("VALIDATION_ERROR", "Required fields are missing for patient registration");                                                                                                                                                                                                                                                                                                                                   +
                                |         }                                                                                                                                                                                                                                                                                                                                                                                                                                                                    +
                                |                                                                                                                                                                                                                                                                                                                                                                                                                                                                              +
                                |         var middleName = getVar('middleName');                                                                                                                                                                                                                                                                                                                                                                                                                               +
                                |         var gender = getVar('gender');                                                                                                                                                                                                                                                                                                                                                                                                                                       +
                                |         var marital = getVar('maritalStatus');                                                                                                                                                                                                                                                                                                                                                                                                                               +
                                |         var country = getVar('country') || 'USA';                                                                                                                                                                                                                                                                                                                                                                                                                            +
                                |         var notes = getVar('patientNotes');                                                                                                                                                                                                                                                                                                                                                                                                                                  +
                                |         var comments = getVar('reviewerComments');                                                                                                                                                                                                                                                                                                                                                                                                                           +
                                |         var ssn = getVar('ssn');                                                                                                                                                                                                                                                                                                                                                                                                                                             +
                                |                                                                                                                                                                                                                                                                                                                                                                                                                                                                              +
                                |         // Build name                                                                                                                                                                                                                                                                                                                                                                                                                                                        +
                                |         var givenNames = [firstName];                                                                                                                                                                                                                                                                                                                                                                                                                                        +
                                |         if (middleName !== '') { givenNames.push(middleName); }                                                                                                                                                                                                                                                                                                                                                                                                              +
                                |                                                                                                                                                                                                                                                                                                                                                                                                                                                                              +
                                |         // Build address                                                                                                                                                                                                                                                                                                                                                                                                                                                     +
                                |         var addrLines = [addr1];                                                                                                                                                                                                                                                                                                                                                                                                                                             +
                                |         var addr2 = getVar('addressLine2');                                                                                                                                                                                                                                                                                                                                                                                                                                  +
                                |         if (addr2 !== '') { addrLines.push(addr2); }                                                                                                                                                                                                                                                                                                                                                                                                                         +
                                |                                                                                                                                                                                                                                                                                                                                                                                                                                                                              +
                                |         // Build telecom                                                                                                                                                                                                                                                                                                                                                                                                                                                     +
