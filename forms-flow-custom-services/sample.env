# ── Application Settings ────────────────────────────────────────────────────
FLASK_APP=run.py
FLASK_ENV=development
FLASK_DEBUG=1
PORT=5005
ENABLE_LOGGER=true
CONFIGURE_LOGS=true
CUSTOM_SERVICES_API_BASE_URL=http://localhost:5005

# ── Security & JWT ─────────────────────────────────────────────────────────
# IMPORTANT: Change these secrets to long, random strings in production
SECRET_KEY=change-me-to-something-secure
JWT_SECRET_KEY=change-me-to-something-secure
JWT_EXPIRY_MINUTES=2880

# ── Magic Link Configuration ───────────────────────────────────────────────
MAGIC_LINK_TOKEN_URL=http://localhost:3000/custom-services/magic-links/public
MAGIC_LINK_EXPIRY_MINUTES=15

# ── FormsFlow.ai Integration ───────────────────────────────────────────────
FORMIO_DEFAULT_PROJECT_URL=http://{your-ip-address}:3001
BPM_API_URL=http://{your-ip-address}:8000/camunda
FORMSFLOW_API_URL=http://{your-ip-address}:5000

# ── Form.io Admin Credentials ──────────────────────────────────────────────
FORMIO_ROOT_EMAIL=admin@example.com
FORMIO_ROOT_PASSWORD=changeme

# ── Keycloak ───────────────────────────────────────────────────────────────
KEYCLOAK_TOKEN_URL=http://{your-ip-address}:8080/auth/realms/forms-flow-ai/protocol/openid-connect/token
KEYCLOAK_BPM_CLIENT_ID=forms-flow-bpm
KEYCLOAK_BPM_CLIENT_SECRET=change-me-to-bpm-client-secret
