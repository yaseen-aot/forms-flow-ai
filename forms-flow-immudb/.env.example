# Forms Flow ImmuDB Worker Service - Environment Configuration
# Copy this file to .env and update the values as needed

# =============================================================================
# Flask Configuration
# =============================================================================
SECRET_KEY=change-me-in-production-use-strong-random-key
DEBUG=false
HOST=0.0.0.0
PORT=5001
FLASK_ENV=production

# =============================================================================
# ImmuDB Configuration
# =============================================================================
IMMUDB_ENABLED=true
IMMUDB_HOST=immudb:3322
IMMUDB_USER=immudb
IMMUDB_PASS=immudb
IMMUDB_ADMIN_PASSWORD=immudb

# Authentication secret key for Fernet encryption (generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())")
IMMUDB_SECRET_KEY=

# =============================================================================
# API Configuration
# =============================================================================
API_PREFIX=/api/v1
CORS_ORIGINS=*

# =============================================================================
# Logging Configuration
# =============================================================================
LOG_LEVEL=INFO

# =============================================================================
# Gunicorn Configuration
# =============================================================================
GUNICORN_WORKERS=4
GUNICORN_THREADS=10
GUNICORN_TIMEOUT=120
