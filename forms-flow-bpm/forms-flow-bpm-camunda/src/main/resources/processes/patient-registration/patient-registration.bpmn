<?xml version="1.0" encoding="UTF-8"?>
<bpmn:definitions
  xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL"
  xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI"
  xmlns:dc="http://www.omg.org/spec/DD/20100524/DC"
  xmlns:di="http://www.omg.org/spec/DD/20100524/DI"
  xmlns:camunda="http://camunda.org/schema/1.0/bpmn"
  xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
  id="Definitions_PatientReg"
  targetNamespace="http://bpmn.io/schema/bpmn"
  exporter="Camunda Modeler"
  exporterVersion="4.8.1">

  <!-- ═══════════════════════════════════════════════════════════════
       PROCESS: patient-registration
       Flow:
         1. Patient submits registration form
         2. Provider reviews and decides Approve / Reject
         3a. Approved → Script Task builds FHIR payload
                      → Service Task POSTs Patient to Epic via EHR Connector
                      → Update status = Approved → End
         3b. Rejected → Update status = Rejected → End
       ═══════════════════════════════════════════════════════════════ -->

  <bpmn:collaboration id="Collaboration_PatientReg">
    <bpmn:participant id="Participant_PatientReg"
                      name="Patient Registration"
                      processRef="patient-registration" />
  </bpmn:collaboration>

  <bpmn:process id="patient-registration"
                name="Patient Registration"
                isExecutable="true"
                camunda:versionTag="1">

    <!-- ─── LANES ─────────────────────────────────────────────────── -->
    <bpmn:laneSet id="LaneSet_PatientReg">
      <bpmn:lane id="Lane_Patient" name="Patient / Submitter">
        <bpmn:flowNodeRef>StartEvent_PatientSubmit</bpmn:flowNodeRef>
      </bpmn:lane>
      <bpmn:lane id="Lane_Provider" name="Provider / Reviewer">
        <bpmn:flowNodeRef>Task_ProviderReview</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Gateway_ProviderDecision</bpmn:flowNodeRef>
      </bpmn:lane>
      <bpmn:lane id="Lane_System" name="System (EHR Integration)">
        <bpmn:flowNodeRef>Task_BuildFHIRPayload</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_WritePatientToEpic</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_UpdateStatusApproved</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_UpdateStatusRejected</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>EndEvent_Approved</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>EndEvent_Rejected</bpmn:flowNodeRef>
      </bpmn:lane>
    </bpmn:laneSet>

    <!-- ─── START EVENT ───────────────────────────────────────────── -->
    <bpmn:startEvent id="StartEvent_PatientSubmit" name="Patient Submits&#10;Registration">
      <bpmn:outgoing>Flow_Start_To_Review</bpmn:outgoing>
    </bpmn:startEvent>

    <!-- ─── FLOW: Start → Provider Review ────────────────────────── -->
    <bpmn:sequenceFlow id="Flow_Start_To_Review"
                       sourceRef="StartEvent_PatientSubmit"
                       targetRef="Task_ProviderReview">
      <bpmn:extensionElements>
        <!-- Set initial application status -->
        <camunda:executionListener event="take">
          <camunda:script scriptFormat="javascript">
            execution.setVariable('applicationStatus', 'New');
          </camunda:script>
        </camunda:executionListener>
        <!-- Sync applicationId + applicationStatus back to formsflow.ai API -->
        <camunda:executionListener
          class="org.camunda.bpm.extension.hooks.listeners.BPMFormDataPipelineListener"
          event="take">
          <camunda:field name="fields">
            <camunda:expression>["applicationId","applicationStatus"]</camunda:expression>
          </camunda:field>
        </camunda:executionListener>
        <!-- Persist application state in formsflow.ai -->
        <camunda:executionListener
          class="org.camunda.bpm.extension.hooks.listeners.ApplicationStateListener"
          event="take" />
      </bpmn:extensionElements>
    </bpmn:sequenceFlow>

    <!-- ─── USER TASK: Provider Review ───────────────────────────── -->
    <!--
      The provider opens the task in formsflow.ai, reviews the patient data,
      fills in "reviewerComments" and sets "action" = Approved | Rejected,
      then completes the task.
    -->
    <bpmn:userTask id="Task_ProviderReview"
                   name="Review Patient&#10;Registration"
                   camunda:candidateGroups="formsflow/formsflow-reviewer">
      <bpmn:extensionElements>
        <!-- On task complete: copy the "action" field as applicationStatus -->
        <camunda:taskListener event="complete">
          <camunda:script scriptFormat="javascript">
            task.execution.setVariable('applicationStatus', task.execution.getVariable('action'));
            task.execution.setVariable('deleteReason', 'completed');
          </camunda:script>
        </camunda:taskListener>
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_Start_To_Review</bpmn:incoming>
      <bpmn:outgoing>Flow_Review_To_Gateway</bpmn:outgoing>
    </bpmn:userTask>

    <!-- ─── FLOW: Provider Review → Gateway ──────────────────────── -->
    <bpmn:sequenceFlow id="Flow_Review_To_Gateway"
                       sourceRef="Task_ProviderReview"
                       targetRef="Gateway_ProviderDecision">
      <bpmn:extensionElements>
        <camunda:executionListener
          class="org.camunda.bpm.extension.hooks.listeners.FormSubmissionListener"
          event="take" />
        <camunda:executionListener
          class="org.camunda.bpm.extension.hooks.listeners.ApplicationStateListener"
          event="take" />
      </bpmn:extensionElements>
    </bpmn:sequenceFlow>

    <!-- ─── GATEWAY: Approved or Rejected? ───────────────────────── -->
    <bpmn:exclusiveGateway id="Gateway_ProviderDecision" name="Provider Decision?">
      <bpmn:incoming>Flow_Review_To_Gateway</bpmn:incoming>
      <bpmn:outgoing>Flow_Gateway_To_BuildPayload</bpmn:outgoing>
      <bpmn:outgoing>Flow_Gateway_To_Rejected</bpmn:outgoing>
    </bpmn:exclusiveGateway>

    <!-- ─── FLOW: Gateway → Build FHIR Payload (Approved) ────────── -->
    <bpmn:sequenceFlow id="Flow_Gateway_To_BuildPayload"
                       name="Approved"
                       sourceRef="Gateway_ProviderDecision"
                       targetRef="Task_BuildFHIRPayload">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">
        ${action == 'Approved'}
      </bpmn:conditionExpression>
    </bpmn:sequenceFlow>

    <!-- ─── SCRIPT TASK: Build FHIR Patient Payload ──────────────── -->
    <!--
      Reads submission variables (set by formsflow.ai via BPMFormDataPipelineListener)
      and constructs the JSON body that will be POSTed to the EHR Connector API.

      Variables available from form submission:
        firstName, middleName, lastName, dateOfBirth, gender, maritalStatus,
        phone, email, addressLine1, addressLine2, city, state, zipCode, country,
        medicalRecordNumber, patientId, patientNotes, reviewerComments
    -->
    <bpmn:scriptTask id="Task_BuildFHIRPayload"
                     name="Build FHIR&#10;Patient Payload"
                     scriptFormat="javascript">
      <bpmn:incoming>Flow_Gateway_To_BuildPayload</bpmn:incoming>
      <bpmn:outgoing>Flow_BuildPayload_To_WriteEpic</bpmn:outgoing>
      <bpmn:script><![CDATA[
        // ── Helper: safe string read from process variables ──────────
        function getVar(name) {
          try {
            var val = execution.getVariable(name);
            return (val !== null && val !== undefined) ? String(val) : '';
          } catch (e) {
            return '';
          }
        }

        // ── Read patient fields from submission ──────────────────────
        var firstName   = getVar('firstName');
        var middleName  = getVar('middleName');
        var lastName    = getVar('lastName');
        var dob         = getVar('dateOfBirth');   // expected: YYYY-MM-DD
        var gender      = getVar('gender');         // male | female | other | unknown
        var phone       = getVar('phone');
        var email       = getVar('email');
        var addr1       = getVar('addressLine1');
        var addr2       = getVar('addressLine2');
        var city        = getVar('city');
        var state       = getVar('state');
        var zipCode     = getVar('zipCode');
        var country     = getVar('country') || 'USA';
        var mrn         = getVar('medicalRecordNumber');
        var epicPtId    = getVar('patientId');
        var marital     = getVar('maritalStatus');
        var language    = getVar('preferredLanguage') || 'English';
        var notes       = getVar('patientNotes');
        var comments    = getVar('reviewerComments');

        // ── Build given names array ─────────────────────────────────
        var givenNames = [firstName];
        if (middleName !== '') { givenNames.push(middleName); }

        // ── Build address lines ─────────────────────────────────────
        var addrLines = [addr1];
        if (addr2 !== '') { addrLines.push(addr2); }

        // ── Build telecom array ─────────────────────────────────────
        var telecom = [];
        if (phone !== '') {
          telecom.push({ system: 'phone', value: phone, use: 'home' });
        }
        if (email !== '') {
          telecom.push({ system: 'email', value: email });
        }

        // ── Build identifier array (MRN) ────────────────────────────
        var identifiers = [];
        if (mrn !== '') {
          identifiers.push({
            use: 'usual',
            type: {
              coding: [{
                system: 'http://terminology.hl7.org/CodeSystem/v2-0203',
                code: 'MR',
                display: 'Medical Record Number'
              }]
            },
            value: mrn
          });
        }

        // ── Build marital status coding ─────────────────────────────
        var maritalObj = null;
        if (marital !== '') {
          maritalObj = {
            coding: [{ system: 'http://terminology.hl7.org/CodeSystem/v3-MaritalStatus', code: marital }]
          };
        }

        // ── Assemble FHIR R4 Patient resource ───────────────────────
        var fhirPatient = {
          resourceType: 'Patient',
          identifier: identifiers,
          active: true,
          name: [{
            use: 'official',
            family: lastName,
            given: givenNames
          }],
          telecom: telecom,
          gender: gender || 'unknown',
          birthDate: dob,
          address: [{
            use: 'home',
            type: 'physical',
            line: addrLines,
            city: city,
            state: state,
            postalCode: zipCode,
            country: country
          }],
          communication: [{
            language: {
              coding: [{
                system: 'urn:ietf:bcp:47',
                display: language
              }]
            },
            preferred: true
          }]
        };

        // Add marital status if present
        if (maritalObj !== null) {
          fhirPatient.maritalStatus = maritalObj;
        }

        // Serialize to JSON string for the HTTP connector
        var payload = JSON.stringify({
          fhirPatient: fhirPatient,
          reviewerComments: comments,
          notes: notes,
          applicationId: getVar('applicationId')
        });

        execution.setVariable('ehrPatientPayload', payload);
        execution.setVariable('ehrEpicPatientId', epicPtId);
      ]]></bpmn:script>
    </bpmn:scriptTask>

    <!-- ─── FLOW: Build Payload → Write to Epic ───────────────────── -->
    <bpmn:sequenceFlow id="Flow_BuildPayload_To_WriteEpic"
                       sourceRef="Task_BuildFHIRPayload"
                       targetRef="Task_WritePatientToEpic" />

    <!-- ─── SERVICE TASK: POST Patient to Epic via EHR Connector ──── -->
    <!--
      Calls POST http://<EHR_CONNECTOR_HOST>:8002/epic/patient-create
      with the FHIR Patient JSON built in the previous script task.

      The EHR Connector service authenticates to Epic via
      SMART Backend Services (private_key_jwt, RS384) and writes
      a FHIR R4 Patient resource.

      Environment variable EHR_CONNECTOR_URL must be set in
      deployment/docker/.env (e.g. http://192.168.1.98:8002)
    -->
    <bpmn:serviceTask id="Task_WritePatientToEpic"
                      name="Write Patient&#10;to Epic (FHIR)">
      <bpmn:extensionElements>
        <camunda:connector>
          <camunda:inputOutput>
            <!-- Target URL — reads EHR_CONNECTOR_URL from Spring env or use literal -->
            <camunda:inputParameter name="url">${EHR_CONNECTOR_URL}/epic/patient-create</camunda:inputParameter>
            <camunda:inputParameter name="method">POST</camunda:inputParameter>
            <camunda:inputParameter name="headers">
              <camunda:map>
                <camunda:entry key="Content-Type">application/json</camunda:entry>
                <camunda:entry key="Accept">application/json</camunda:entry>
              </camunda:map>
            </camunda:inputParameter>
            <camunda:inputParameter name="payload">${ehrPatientPayload}</camunda:inputParameter>
            <!-- Capture the response body -->
            <camunda:outputParameter name="ehrResponse">${response}</camunda:outputParameter>
          </camunda:inputOutput>
          <camunda:connectorId>http-connector</camunda:connectorId>
        </camunda:connector>
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_BuildPayload_To_WriteEpic</bpmn:incoming>
      <bpmn:outgoing>Flow_WriteEpic_To_UpdateApproved</bpmn:outgoing>
    </bpmn:serviceTask>

    <!-- ─── FLOW: Write Epic → Update Status Approved ────────────── -->
    <bpmn:sequenceFlow id="Flow_WriteEpic_To_UpdateApproved"
                       sourceRef="Task_WritePatientToEpic"
                       targetRef="Task_UpdateStatusApproved" />

    <!-- ─── TASK: Update Application Status → Approved ───────────── -->
    <bpmn:task id="Task_UpdateStatusApproved" name="Update Status&#10;Approved">
      <bpmn:extensionElements>
        <camunda:executionListener
          class="org.camunda.bpm.extension.hooks.listeners.ApplicationStateListener"
          event="end" />
        <camunda:executionListener
          class="org.camunda.bpm.extension.hooks.listeners.BPMFormDataPipelineListener"
          event="start">
          <camunda:field name="fields">
            <camunda:expression>["applicationId","applicationStatus"]</camunda:expression>
          </camunda:field>
        </camunda:executionListener>
        <camunda:executionListener
          class="org.camunda.bpm.extension.hooks.listeners.FormSubmissionListener"
          event="start" />
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_WriteEpic_To_UpdateApproved</bpmn:incoming>
      <bpmn:outgoing>Flow_UpdateApproved_To_End</bpmn:outgoing>
    </bpmn:task>

    <!-- ─── FLOW: Update Approved → End ──────────────────────────── -->
    <bpmn:sequenceFlow id="Flow_UpdateApproved_To_End"
                       sourceRef="Task_UpdateStatusApproved"
                       targetRef="EndEvent_Approved" />

    <!-- ─── END EVENT: Approved ──────────────────────────────────── -->
    <bpmn:endEvent id="EndEvent_Approved" name="Patient Registered&#10;in Epic">
      <bpmn:incoming>Flow_UpdateApproved_To_End</bpmn:incoming>
    </bpmn:endEvent>

    <!-- ─── FLOW: Gateway → Rejected ─────────────────────────────── -->
    <bpmn:sequenceFlow id="Flow_Gateway_To_Rejected"
                       name="Rejected"
                       sourceRef="Gateway_ProviderDecision"
                       targetRef="Task_UpdateStatusRejected">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">
        ${action == 'Rejected'}
      </bpmn:conditionExpression>
    </bpmn:sequenceFlow>

    <!-- ─── TASK: Update Application Status → Rejected ───────────── -->
    <bpmn:task id="Task_UpdateStatusRejected" name="Update Status&#10;Rejected">
      <bpmn:extensionElements>
        <camunda:executionListener
          class="org.camunda.bpm.extension.hooks.listeners.ApplicationStateListener"
          event="end" />
        <camunda:executionListener
          class="org.camunda.bpm.extension.hooks.listeners.BPMFormDataPipelineListener"
          event="start">
          <camunda:field name="fields">
            <camunda:expression>["applicationId","applicationStatus"]</camunda:expression>
          </camunda:field>
        </camunda:executionListener>
        <camunda:executionListener
          class="org.camunda.bpm.extension.hooks.listeners.FormSubmissionListener"
          event="start" />
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_Gateway_To_Rejected</bpmn:incoming>
      <bpmn:outgoing>Flow_UpdateRejected_To_End</bpmn:outgoing>
    </bpmn:task>

    <!-- ─── FLOW: Update Rejected → End ──────────────────────────── -->
    <bpmn:sequenceFlow id="Flow_UpdateRejected_To_End"
                       sourceRef="Task_UpdateStatusRejected"
                       targetRef="EndEvent_Rejected" />

    <!-- ─── END EVENT: Rejected ──────────────────────────────────── -->
    <bpmn:endEvent id="EndEvent_Rejected" name="Registration&#10;Rejected">
      <bpmn:incoming>Flow_UpdateRejected_To_End</bpmn:incoming>
    </bpmn:endEvent>

  </bpmn:process>

  <!-- ═══════════════════════════════════════════════════════════════
       DIAGRAM LAYOUT
       ═══════════════════════════════════════════════════════════════ -->
  <bpmndi:BPMNDiagram id="BPMNDiagram_PatientReg">
    <bpmndi:BPMNPlane id="BPMNPlane_PatientReg" bpmnElement="Collaboration_PatientReg">

      <!-- Participant / Pool -->
      <bpmndi:BPMNShape id="Participant_PatientReg_di" bpmnElement="Participant_PatientReg" isHorizontal="true">
        <dc:Bounds x="130" y="80" width="1050" height="590" />
      </bpmndi:BPMNShape>

      <!-- Lanes -->
      <bpmndi:BPMNShape id="Lane_Patient_di" bpmnElement="Lane_Patient" isHorizontal="true">
        <dc:Bounds x="160" y="80" width="1020" height="130" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Lane_Provider_di" bpmnElement="Lane_Provider" isHorizontal="true">
        <dc:Bounds x="160" y="210" width="1020" height="160" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Lane_System_di" bpmnElement="Lane_System" isHorizontal="true">
        <dc:Bounds x="160" y="370" width="1020" height="300" />
      </bpmndi:BPMNShape>

      <!-- Start Event -->
      <bpmndi:BPMNShape id="StartEvent_PatientSubmit_di" bpmnElement="StartEvent_PatientSubmit">
        <dc:Bounds x="222" y="127" width="36" height="36" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="200" y="170" width="80" height="27" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>

      <!-- Provider Review User Task -->
      <bpmndi:BPMNShape id="Task_ProviderReview_di" bpmnElement="Task_ProviderReview">
        <dc:Bounds x="330" y="250" width="120" height="80" />
      </bpmndi:BPMNShape>

      <!-- Gateway -->
      <bpmndi:BPMNShape id="Gateway_ProviderDecision_di" bpmnElement="Gateway_ProviderDecision" isMarkerVisible="true">
        <dc:Bounds x="525" y="270" width="50" height="50" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="500" y="328" width="100" height="14" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>

      <!-- Build FHIR Payload Script Task -->
      <bpmndi:BPMNShape id="Task_BuildFHIRPayload_di" bpmnElement="Task_BuildFHIRPayload">
        <dc:Bounds x="620" y="400" width="120" height="80" />
      </bpmndi:BPMNShape>

      <!-- Write Patient to Epic Service Task -->
      <bpmndi:BPMNShape id="Task_WritePatientToEpic_di" bpmnElement="Task_WritePatientToEpic">
        <dc:Bounds x="800" y="400" width="120" height="80" />
      </bpmndi:BPMNShape>

      <!-- Update Status Approved Task -->
      <bpmndi:BPMNShape id="Task_UpdateStatusApproved_di" bpmnElement="Task_UpdateStatusApproved">
        <dc:Bounds x="980" y="400" width="120" height="80" />
      </bpmndi:BPMNShape>

      <!-- End Event Approved -->
      <bpmndi:BPMNShape id="EndEvent_Approved_di" bpmnElement="EndEvent_Approved">
        <dc:Bounds x="1072" y="552" width="36" height="36" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="1048" y="595" width="84" height="27" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>

      <!-- Update Status Rejected Task -->
      <bpmndi:BPMNShape id="Task_UpdateStatusRejected_di" bpmnElement="Task_UpdateStatusRejected">
        <dc:Bounds x="620" y="570" width="120" height="80" />
      </bpmndi:BPMNShape>

      <!-- End Event Rejected -->
      <bpmndi:BPMNShape id="EndEvent_Rejected_di" bpmnElement="EndEvent_Rejected">
        <dc:Bounds x="802" y="592" width="36" height="36" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="781" y="635" width="78" height="27" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>

      <!-- EDGES -->

      <!-- Start → Provider Review -->
      <bpmndi:BPMNEdge id="Flow_Start_To_Review_di" bpmnElement="Flow_Start_To_Review">
        <di:waypoint x="240" y="163" />
        <di:waypoint x="240" y="290" />
        <di:waypoint x="330" y="290" />
      </bpmndi:BPMNEdge>

      <!-- Provider Review → Gateway -->
      <bpmndi:BPMNEdge id="Flow_Review_To_Gateway_di" bpmnElement="Flow_Review_To_Gateway">
        <di:waypoint x="450" y="290" />
        <di:waypoint x="525" y="295" />
      </bpmndi:BPMNEdge>

      <!-- Gateway → Build FHIR Payload (Approved) -->
      <bpmndi:BPMNEdge id="Flow_Gateway_To_BuildPayload_di" bpmnElement="Flow_Gateway_To_BuildPayload">
        <di:waypoint x="550" y="320" />
        <di:waypoint x="550" y="440" />
        <di:waypoint x="620" y="440" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="556" y="355" width="48" height="14" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNEdge>

      <!-- Build Payload → Write to Epic -->
      <bpmndi:BPMNEdge id="Flow_BuildPayload_To_WriteEpic_di" bpmnElement="Flow_BuildPayload_To_WriteEpic">
        <di:waypoint x="740" y="440" />
        <di:waypoint x="800" y="440" />
      </bpmndi:BPMNEdge>

      <!-- Write Epic → Update Approved -->
      <bpmndi:BPMNEdge id="Flow_WriteEpic_To_UpdateApproved_di" bpmnElement="Flow_WriteEpic_To_UpdateApproved">
        <di:waypoint x="920" y="440" />
        <di:waypoint x="980" y="440" />
      </bpmndi:BPMNEdge>

      <!-- Update Approved → End Approved -->
      <bpmndi:BPMNEdge id="Flow_UpdateApproved_To_End_di" bpmnElement="Flow_UpdateApproved_To_End">
        <di:waypoint x="1040" y="480" />
        <di:waypoint x="1040" y="570" />
        <di:waypoint x="1072" y="570" />
      </bpmndi:BPMNEdge>

      <!-- Gateway → Update Rejected -->
      <bpmndi:BPMNEdge id="Flow_Gateway_To_Rejected_di" bpmnElement="Flow_Gateway_To_Rejected">
        <di:waypoint x="550" y="320" />
        <di:waypoint x="550" y="610" />
        <di:waypoint x="620" y="610" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="556" y="455" width="44" height="14" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNEdge>

      <!-- Update Rejected → End Rejected -->
      <bpmndi:BPMNEdge id="Flow_UpdateRejected_To_End_di" bpmnElement="Flow_UpdateRejected_To_End">
        <di:waypoint x="740" y="610" />
        <di:waypoint x="802" y="610" />
      </bpmndi:BPMNEdge>

    </bpmndi:BPMNPlane>
  </bpmndi:BPMNDiagram>

</bpmn:definitions>
