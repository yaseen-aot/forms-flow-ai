{
  "title": "Patient Registration",
  "name": "patientRegistration",
  "path": "patientregistration",
  "type": "form",
  "display": "form",
  "components": [
    {
      "type": "panel",
      "title": "Patient Information",
      "key": "patientInformationPanel",
      "theme": "primary",
      "collapsible": false,
      "input": false,
      "tableView": false,
      "components": [
        {
          "type": "columns",
          "key": "nameColumns",
          "input": false,
          "tableView": false,
          "columns": [
            {
              "components": [
                {
                  "type": "textfield",
                  "key": "firstName",
                  "label": "First Name",
                  "placeholder": "Enter first name",
                  "input": true,
                  "tableView": true,
                  "validate": {
                    "required": true,
                    "maxLength": 50
                  }
                }
              ],
              "width": 4,
              "offset": 0,
              "push": 0,
              "pull": 0
            },
            {
              "components": [
                {
                  "type": "textfield",
                  "key": "middleName",
                  "label": "Middle Name",
                  "placeholder": "Enter middle name",
                  "input": true,
                  "tableView": true,
                  "validate": {
                    "required": false,
                    "maxLength": 50
                  }
                }
              ],
              "width": 4,
              "offset": 0,
              "push": 0,
              "pull": 0
            },
            {
              "components": [
                {
                  "type": "textfield",
                  "key": "lastName",
                  "label": "Last Name",
                  "placeholder": "Enter last name",
                  "input": true,
                  "tableView": true,
                  "validate": {
                    "required": true,
                    "maxLength": 50
                  }
                }
              ],
              "width": 4,
              "offset": 0,
              "push": 0,
              "pull": 0
            }
          ]
        },
        {
          "type": "columns",
          "key": "dobGenderColumns",
          "input": false,
          "tableView": false,
          "columns": [
            {
              "components": [
                {
                  "type": "datetime",
                  "key": "dateOfBirth",
                  "label": "Date of Birth",
                  "placeholder": "MM/DD/YYYY",
                  "input": true,
                  "tableView": true,
                  "format": "MM/dd/yyyy",
                  "enableMinDateInput": false,
                  "enableMaxDateInput": false,
                  "datePicker": {
                    "disableWeekends": false,
                    "disableWeekdays": false
                  },
                  "enableTime": false,
                  "validate": {
                    "required": true
                  }
                }
              ],
              "width": 4,
              "offset": 0,
              "push": 0,
              "pull": 0
            },
            {
              "components": [
                {
                  "type": "select",
                  "key": "gender",
                  "label": "Gender",
                  "input": true,
                  "tableView": true,
                  "data": {
                    "values": [
                      { "label": "Male", "value": "male" },
                      { "label": "Female", "value": "female" },
                      { "label": "Other", "value": "other" },
                      { "label": "Unknown", "value": "unknown" }
                    ]
                  },
                  "validate": {
                    "required": true
                  }
                }
              ],
              "width": 4,
              "offset": 0,
              "push": 0,
              "pull": 0
            },
            {
              "components": [
                {
                  "type": "select",
                  "key": "maritalStatus",
                  "label": "Marital Status",
                  "input": true,
                  "tableView": true,
                  "data": {
                    "values": [
                      { "label": "Single", "value": "S" },
                      { "label": "Married", "value": "M" },
                      { "label": "Divorced", "value": "D" },
                      { "label": "Widowed", "value": "W" },
                      { "label": "Unknown", "value": "UNK" }
                    ]
                  },
                  "validate": {
                    "required": false
                  }
                }
              ],
              "width": 4,
              "offset": 0,
              "push": 0,
              "pull": 0
            }
          ]
        },
        {
          "type": "columns",
          "key": "languageRaceColumns",
          "input": false,
          "tableView": false,
          "columns": [
            {
              "components": [
                {
                  "type": "textfield",
                  "key": "preferredLanguage",
                  "label": "Preferred Language",
                  "placeholder": "e.g. English",
                  "input": true,
                  "tableView": true,
                  "defaultValue": "English",
                  "validate": {
                    "required": false
                  }
                }
              ],
              "width": 6,
              "offset": 0,
              "push": 0,
              "pull": 0
            },
            {
              "components": [
                {
                  "type": "textfield",
                  "key": "race",
                  "label": "Race / Ethnicity",
                  "placeholder": "Enter race or ethnicity",
                  "input": true,
                  "tableView": false,
                  "validate": {
                    "required": false
                  }
                }
              ],
              "width": 6,
              "offset": 0,
              "push": 0,
              "pull": 0
            }
          ]
        }
      ]
    },
    {
      "type": "panel",
      "title": "Contact Information",
      "key": "contactInformationPanel",
      "theme": "primary",
      "collapsible": false,
      "input": false,
      "tableView": false,
      "components": [
        {
          "type": "columns",
          "key": "phoneEmailColumns",
          "input": false,
          "tableView": false,
          "columns": [
            {
              "components": [
                {
                  "type": "phoneNumber",
                  "key": "phone",
                  "label": "Phone Number",
                  "placeholder": "(xxx) xxx-xxxx",
                  "input": true,
                  "tableView": true,
                  "validate": {
                    "required": true
                  }
                }
              ],
              "width": 6,
              "offset": 0,
              "push": 0,
              "pull": 0
            },
            {
              "components": [
                {
                  "type": "email",
                  "key": "email",
                  "label": "Email Address",
                  "placeholder": "Enter email address",
                  "input": true,
                  "tableView": true,
                  "validate": {
                    "required": false
                  }
                }
              ],
              "width": 6,
              "offset": 0,
              "push": 0,
              "pull": 0
            }
          ]
        },
        {
          "type": "textfield",
          "key": "addressLine1",
          "label": "Address Line 1",
          "placeholder": "Street address",
          "input": true,
          "tableView": true,
          "validate": {
            "required": true,
            "maxLength": 100
          }
        },
        {
          "type": "textfield",
          "key": "addressLine2",
          "label": "Address Line 2",
          "placeholder": "Apt, Suite, Unit (optional)",
          "input": true,
          "tableView": false,
          "validate": {
            "required": false,
            "maxLength": 100
          }
        },
        {
          "type": "columns",
          "key": "cityStateZipColumns",
          "input": false,
          "tableView": false,
          "columns": [
            {
              "components": [
                {
                  "type": "textfield",
                  "key": "city",
                  "label": "City",
                  "placeholder": "City",
                  "input": true,
                  "tableView": true,
                  "validate": {
                    "required": true
                  }
                }
              ],
              "width": 4,
              "offset": 0,
              "push": 0,
              "pull": 0
            },
            {
              "components": [
                {
                  "type": "textfield",
                  "key": "state",
                  "label": "State / Province",
                  "placeholder": "State",
                  "input": true,
                  "tableView": true,
                  "validate": {
                    "required": true
                  }
                }
              ],
              "width": 4,
              "offset": 0,
              "push": 0,
              "pull": 0
            },
            {
              "components": [
                {
                  "type": "textfield",
                  "key": "zipCode",
                  "label": "ZIP / Postal Code",
                  "placeholder": "ZIP Code",
                  "input": true,
                  "tableView": true,
                  "validate": {
                    "required": true,
                    "maxLength": 10
                  }
                }
              ],
              "width": 4,
              "offset": 0,
              "push": 0,
              "pull": 0
            }
          ]
        },
        {
          "type": "textfield",
          "key": "country",
          "label": "Country",
          "placeholder": "Country",
          "defaultValue": "USA",
          "input": true,
          "tableView": false,
          "validate": {
            "required": false
          }
        }
      ]
    },
    {
      "type": "panel",
      "title": "Patient Identifiers",
      "key": "identifiersPanel",
      "theme": "info",
      "collapsible": true,
      "collapsed": false,
      "input": false,
      "tableView": false,
      "components": [
        {
          "type": "columns",
          "key": "identifierColumns",
          "input": false,
          "tableView": false,
          "columns": [
            {
              "components": [
                {
                  "type": "textfield",
                  "key": "medicalRecordNumber",
                  "label": "Medical Record Number (MRN)",
                  "placeholder": "Auto-populated from EHR",
                  "input": true,
                  "tableView": true,
                  "disabled": true,
                  "description": "Populated automatically when launched from Epic",
                  "validate": {
                    "required": false
                  }
                }
              ],
              "width": 6,
              "offset": 0,
              "push": 0,
              "pull": 0
            },
            {
              "components": [
                {
                  "type": "textfield",
                  "key": "patientId",
                  "label": "EHR Patient ID",
                  "placeholder": "Auto-populated from EHR",
                  "input": true,
                  "tableView": false,
                  "disabled": true,
                  "description": "Epic patient identifier — do not edit",
                  "validate": {
                    "required": false
                  }
                }
              ],
              "width": 6,
              "offset": 0,
              "push": 0,
              "pull": 0
            }
          ]
        }
      ]
    },
    {
      "type": "panel",
      "title": "Additional Notes",
      "key": "additionalNotesPanel",
      "theme": "default",
      "collapsible": true,
      "collapsed": false,
      "input": false,
      "tableView": false,
      "components": [
        {
          "type": "textarea",
          "key": "patientNotes",
          "label": "Patient Notes",
          "placeholder": "Any additional notes or clinical context...",
          "input": true,
          "tableView": false,
          "rows": 4,
          "validate": {
            "required": false,
            "maxLength": 1000
          }
        }
      ]
    },
    {
      "type": "panel",
      "title": "Provider Review",
      "key": "providerReviewPanel",
      "theme": "warning",
      "collapsible": false,
      "input": false,
      "tableView": false,
      "conditional": {
        "show": true,
        "when": null,
        "eq": ""
      },
      "components": [
        {
          "type": "textarea",
          "key": "reviewerComments",
          "label": "Reviewer Comments",
          "placeholder": "Enter comments or reason for rejection...",
          "input": true,
          "tableView": false,
          "rows": 3,
          "validate": {
            "required": false
          }
        },
        {
          "type": "select",
          "key": "action",
          "label": "Action",
          "input": true,
          "tableView": true,
          "data": {
            "values": [
              { "label": "Approve — Register Patient in Epic", "value": "Approved" },
              { "label": "Reject — Do Not Register", "value": "Rejected" }
            ]
          },
          "defaultValue": "",
          "validate": {
            "required": false
          },
          "description": "Only visible to the assigned provider/reviewer"
        }
      ]
    },
    {
      "type": "button",
      "key": "submit",
      "label": "Submit Registration",
      "action": "submit",
      "input": true,
      "tableView": false,
      "theme": "primary",
      "size": "md",
      "block": false,
      "leftIcon": "",
      "rightIcon": "",
      "disableOnInvalid": true
    }
  ]
}
