              "widget": "html5",
              "tableView": true,
              "validateWhenHidden": false,
              "key": "action",
              "type": "select",
              "input": true,
              "defaultValue": "",
              "description": "Only visible to the assigned provider/reviewer",
              "data": {
                "values": [
                  {
                    "label": "Approve \u2014 Register Patient in Epic",
                    "value": "Approved"
                  },
                  {
                    "label": "Return to Submitter \u2014 Request Info/Edits",
                    "value": "Returned"
                  },
                  {
                    "label": "Reject \u2014 Do Not Register",
                    "value": "Rejected"
                  }
                ]
              },
              "validate": {
                "required": false
              }
            },
            {
              "type": "button",
              "key": "submitAction",
              "label": "Submit Review",
              "action": "custom",
              "input": true,
              "tableView": false,
              "theme": "primary",
              "size": "md",
              "block": false,
              "leftIcon": "",
              "rightIcon": "",
              "disableOnInvalid": false,
              "customConditional": "const status = data.applicationStatus;\nif (status === 'Resubmit' || status === 'Approved' || status === 'Rejected') {\n  show = false;\n} else {\n  show = true;\n  if(data.personalInformation && data.personalInformation.action){\n    component.disabled=false;\n  }else{\n    component.disabled=true;\n  }\n}",
              "custom": "form.formio.saveSubmission(form.submission).then(result => {\n  console.log('Submission saved:', result);\n  form.emit('customEvent', {\n    type: \"actionComplete\",\n    component: component,\n    actionType: form.submission.data.personalInformation.action\n  });\n}).catch(error => {\n  console.error('Error saving submission:', error);\n});"
            }
