          "theme": "warning",
          "conditional": {
            "show": null,
            "when": null,
            "eq": "",
            "json": ""
          },
          "customConditional": "const UserDetails = JSON.parse(localStorage.getItem(\"UserDetails\"));\nconst groups = UserDetails ? UserDetails[\"groups\"] : [];\nconst isReviewer = groups.includes(\"/formsflow/formsflow-reviewer\");\nconst status = data.applicationStatus;\nif ((isReviewer && (status === \"New\" || status === \"Resubmitted\")) || status === \"Resubmit\" || status === \"Approved\" || status === \"Rejected\") {\n  show = true;\n}\nelse {\n  show = false;\n};",
