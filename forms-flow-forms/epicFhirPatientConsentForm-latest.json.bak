                "type": "button",
                "custom": "const submissionId = form._submission._id;\n// Set base URL \nFormio.setBaseUrl(form.formio.projectUrl + '/formio');\n\nconst formRelativePath = '/form/' + form.formio.formId;\n\nconst submissionObj = {\n  _id: submissionId,\n  data: data\n};\n// Create Formio instance using relative path\nconst formio = new Formio(formRelativePath);\nformio.saveSubmission(submissionObj).then(result => {\n  console.log('Submission saved:', result);\n  form.emit('customEvent', {\n    type: \"actionComplete\",\n    component: component,\n    actionType: data.actionType\n  });\n}).catch(error => {\n  console.error('Error saving submission:', error);\n});",
