  "workflows": [
    {
      "processKey": "freedomofinformationandprotectionofprivacy-copy-copy-copy2876",
      "processName": "freedomofinformationandprotectionofprivacy-copy-copy-copy2876",
      "processType": "BPMN",
      "type": "main",
      "content": "<?xml version=\"1.0\" encoding=\"UTF-8\"?>\n<bpmn:definitions xmlns:bpmn=\"http://www.omg.org/spec/BPMN/20100524/MODEL\" xmlns:bpmndi=\"http://www.omg.org/spec/BPMN/20100524/DI\" xmlns:dc=\"http://www.omg.org/spec/DD/20100524/DC\" xmlns:camunda=\"http://camunda.org/schema/1.0/bpmn\" xmlns:xsi=\"http://www.w3.org/2001/XMLSchema-instance\" xmlns:di=\"http://www.omg.org/spec/DD/20100524/DI\" id=\"Definitions_0993co4\" targetNamespace=\"http://bpmn.io/schema/bpmn\" exporter=\"Camunda Modeler\" exporterVersion=\"4.8.1\">\n  <bpmn:process id=\"freedomofinformationandprotectionofprivacy-copy-copy-copy2876\" name=\"freedomofinformationandprotectionofprivacy-copy-copy-copy2876\" isExecutable=\"true\" camunda:versionTag=\"1\">\n    <bpmn:startEvent id=\"StartEvent_1\" name=\"Start Request\">\n      <bpmn:extensionElements>\n        <camunda:executionListener event=\"start\">\n          <camunda:script scriptFormat=\"javascript\">\n// surrogateKey arrives from form submission as a process variable.\n// Fallback: generate server-side if for any reason it is empty.\nvar existing = execution.getVariable('surrogateKey');\nif (!existing || existing === '') {\n  var uuid = java.util.UUID.randomUUID().toString();\n  execution.setVariable('surrogateKey', uuid);\n}\n          </camunda:script>\n        </camunda:executionListener>\n      </bpmn:extensionElements>\n      <bpmn:outgoing>SequenceFlow_0ociprs</bpmn:outgoing>\n    </bpmn:startEvent>\n    <bpmn:sequenceFlow id=\"SequenceFlow_0ociprs\" sourceRef=\"StartEvent_1\" targetRef=\"reviewer\">\n      <bpmn:extensionElements>\n        <camunda:executionListener event=\"take\">\n          <camunda:script scriptFormat=\"javascript\">execution.setVariable('applicationStatus', 'New');\nexecution.setVariable(\"surrogateKey\", execution.getVariable(\"surrogateKey\"));</camunda:script>\n        </camunda:executionListener>\n        <camunda:executionListener class=\"org.camunda.bpm.extension.hooks.listeners.BPMFormDataPipelineListener\" event=\"take\">\n          <camunda:field name=\"fields\">\n            <camunda:expression>[\"applicationId\",\"applicationStatus\",\"medicalRecordNumber\",\"surrogateKey\"]</camunda:expression>\n          </camunda:field>\n        </camunda:executionListener>\n        <camunda:executionListener class=\"org.camunda.bpm.extension.hooks.listeners.ApplicationStateListener\" event=\"take\"/>\n      </bpmn:extensionElements>\n    </bpmn:sequenceFlow>\n    <bpmn:userTask id=\"reviewer\" name=\"Review Submission\" camunda:assignee=\"\" camunda:candidateGroups=\"formsflow/formsflow-reviewer/approver\">\n      <bpmn:extensionElements>\n        <camunda:formData>\n          <camunda:formField id=\"action\" label=\"Action\" type=\"string\"/>\n          <camunda:formField id=\"surrogateKey\" label=\"Surrogate Key\" type=\"string\"/>\n        </camunda:formData>\n        <camunda:taskListener event=\"create\" id=\"\">\n          <camunda:script scriptFormat=\"javascript\">\ntask.setVariable('surrogateKey', task.getVariable('surrogateKey'));\n          </camunda:script>\n        </camunda:taskListener>\n        <camunda:taskListener event=\"complete\">\n          <camunda:script scriptFormat=\"javascript\">\ntask.setVariable('applicationStatus', task.getVariable('action'));\ntask.setVariable('deleteReason', \"completed\");\ntask.setVariable('surrogateKey', task.getVariable('surrogateKey'));\n          </camunda:script>\n        </camunda:taskListener>\n      </bpmn:extensionElements>\n      <bpmn:incoming>SequenceFlow_0ociprs</bpmn:incoming>\n      <bpmn:outgoing>SequenceFlow_0jg4sg3</bpmn:outgoing>\n    </bpmn:userTask>\n    <bpmn:sequenceFlow id=\"SequenceFlow_0jg4sg3\" sourceRef=\"reviewer\" targetRef=\"ExclusiveGateway_0l1c65j\"/>\n    <bpmn:exclusiveGateway id=\"ExclusiveGateway_0l1c65j\" name=\"Action Taken?\">\n      <bpmn:extensionElements>\n        <camunda:executionListener event=\"start\">\n          <camunda:script scriptFormat=\"javascript\">\nexecution.setVariable('surrogateKey', execution.getVariable('surrogateKey'));\n          </camunda:script>\n        </camunda:executionListener>\n      </bpmn:extensionElements>\n      <bpmn:incoming>SequenceFlow_0jg4sg3</bpmn:incoming>\n      <bpmn:outgoing>SequenceFlow_1x38yu4</bpmn:outgoing>\n      <bpmn:outgoing>SequenceFlow_0pc6hcp</bpmn:outgoing>\n    </bpmn:exclusiveGateway>\n    <bpmn:sequenceFlow id=\"SequenceFlow_1x38yu4\" name=\"approve\" sourceRef=\"ExclusiveGateway_0l1c65j\" targetRef=\"Task_1hko8r7\">\n      <bpmn:conditionExpression xsi:type=\"bpmn:tFormalExpression\">${action == 'Approved'}</bpmn:conditionExpression>\n    </bpmn:sequenceFlow>\n    <bpmn:sequenceFlow id=\"SequenceFlow_0pc6hcp\" name=\"reject\" sourceRef=\"ExclusiveGateway_0l1c65j\" targetRef=\"Task_1hko8r7\">\n      <bpmn:conditionExpression xsi:type=\"bpmn:tFormalExpression\">${action == 'Rejected'}</bpmn:conditionExpression>\n    </bpmn:sequenceFlow>\n    <bpmn:task id=\"Task_1hko8r7\" name=\"Update Application Status\">\n      <bpmn:extensionElements>\n        <camunda:executionListener event=\"start\">\n          <camunda:script scriptFormat=\"javascript\">\nexecution.setVariable('surrogateKey', execution.getVariable('surrogateKey'));\n          </camunda:script>\n        </camunda:executionListener>\n        <camunda:executionListener class=\"org.camunda.bpm.extension.hooks.listeners.BPMFormDataPipelineListener\" event=\"start\">\n          <camunda:field name=\"fields\">\n            <camunda:expression>[\"applicationId\",\"applicationStatus\",\"surrogateKey\"]</camunda:expression>\n          </camunda:field>\n        </camunda:executionListener>\n        <camunda:executionListener class=\"org.camunda.bpm.extension.hooks.listeners.FormSubmissionListener\" event=\"start\"/>\n        <camunda:executionListener class=\"org.camunda.bpm.extension.hooks.listeners.ApplicationStateListener\" event=\"end\"/>\n      </bpmn:extensionElements>\n      <bpmn:incoming>SequenceFlow_1x38yu4</bpmn:incoming>\n      <bpmn:incoming>SequenceFlow_0pc6hcp</bpmn:incoming>\n      <bpmn:outgoing>SequenceFlow_00bn1p7</bpmn:outgoing>\n    </bpmn:task>\n    <bpmn:sequenceFlow id=\"SequenceFlow_00bn1p7\" sourceRef=\"Task_1hko8r7\" targetRef=\"Activity_1gtnbpo\"/>\n    <bpmn:serviceTask id=\"Activity_1gtnbpo\" name=\"SendBackApproval\">\n      <bpmn:extensionElements>\n        <camunda:connector>\n          <camunda:inputOutput>\n            <camunda:inputParameter name=\"url\">https://fhir-connector.aot-technologies.com/epic/approve</camunda:inputParameter>\n            <camunda:inputParameter name=\"method\">POST</camunda:inputParameter>\n            <camunda:inputParameter name=\"headers\">\n              <camunda:map>\n                <camunda:entry key=\"Content-Type\">application/json</camunda:entry>\n              </camunda:map>\n            </camunda:inputParameter>\n            <camunda:inputParameter name=\"payload\">\n              <camunda:script scriptFormat=\"javascript\">\nvar patientId     = execution.getVariable(\"patientId\");\nvar surrogateKey  = execution.getVariable(\"surrogateKey\");\nvar applicationId = execution.getVariable(\"applicationId\");\nvar approvedAt    = new Date().toISOString();\n\nJSON.stringify({\n  \"patientId\":     patientId,\n  \"applicationId\": applicationId,\n  \"surrogateKey\":  surrogateKey,\n  \"consentText\":   \"Patient has approved the consent form.\",\n  \"approvedAt\":    approvedAt\n});\n              </camunda:script>\n            </camunda:inputParameter>\n            <camunda:outputParameter name=\"epicResponse\">\n              <camunda:script scriptFormat=\"javascript\">var responseBody = connector.getVariable(\"response\");\nresponseBody;</camunda:script>\n            </camunda:outputParameter>\n          </camunda:inputOutput>\n          <camunda:connectorId>http-connector</camunda:connectorId>\n        </camunda:connector>\n      </bpmn:extensionElements>\n      <bpmn:incoming>SequenceFlow_00bn1p7</bpmn:incoming>\n      <bpmn:outgoing>Flow_1cbkpva</bpmn:outgoing>\n    </bpmn:serviceTask>\n    <bpmn:endEvent id=\"EndEvent_03cla68\">\n      <bpmn:incoming>Flow_1cbkpva</bpmn:incoming>\n    </bpmn:endEvent>\n    <bpmn:sequenceFlow id=\"Flow_1cbkpva\" sourceRef=\"Activity_1gtnbpo\" targetRef=\"EndEvent_03cla68\"/>\n  </bpmn:process>\n  <bpmn:message id=\"Message_1ihrno3\" name=\"Message_Email\"/>\n  <bpmndi:BPMNDiagram id=\"BPMNDiagram_1\">\n    <bpmndi:BPMNPlane id=\"BPMNPlane_1\" bpmnElement=\"freedomofinformationandprotectionofprivacy-copy-copy-copy2876\">\n      <bpmndi:BPMNShape id=\"_BPMNShape_StartEvent_2\" bpmnElement=\"StartEvent_1\">\n        <dc:Bounds x=\"179\" y=\"99\" width=\"36\" height=\"36\"/>\n        <bpmndi:BPMNLabel>\n          <dc:Bounds x=\"163\" y=\"75\" width=\"68\" height=\"14\"/>\n        </bpmndi:BPMNLabel>\n      </bpmndi:BPMNShape>\n      <bpmndi:BPMNShape id=\"UserTask_0l4y66o_di\" bpmnElement=\"reviewer\">\n        <dc:Bounds x=\"300\" y=\"77\" width=\"100\" height=\"80\"/>\n      </bpmndi:BPMNShape>\n      <bpmndi:BPMNShape id=\"ExclusiveGateway_0l1c65j_di\" bpmnElement=\"ExclusiveGateway_0l1c65j\" isMarkerVisible=\"true\">\n        <dc:Bounds x=\"505\" y=\"92\" width=\"50\" height=\"50\"/>\n        <bpmndi:BPMNLabel>\n          <dc:Bounds x=\"496\" y=\"68\" width=\"69\" height=\"14\"/>\n        </bpmndi:BPMNLabel>\n      </bpmndi:BPMNShape>\n      <bpmndi:BPMNShape id=\"Task_0fde0ul_di\" bpmnElement=\"Task_1hko8r7\">\n        <dc:Bounds x=\"660\" y=\"97\" width=\"100\" height=\"80\"/>\n      </bpmndi:BPMNShape>\n      <bpmndi:BPMNShape id=\"Activity_0jfwyr8_di\" bpmnElement=\"Activity_1gtnbpo\">\n        <dc:Bounds x=\"790\" y=\"97\" width=\"100\" height=\"80\"/>\n        <bpmndi:BPMNLabel/>\n      </bpmndi:BPMNShape>\n      <bpmndi:BPMNShape id=\"EndEvent_03cla68_di\" bpmnElement=\"EndEvent_03cla68\">\n        <dc:Bounds x=\"922\" y=\"119\" width=\"36\" height=\"36\"/>\n      </bpmndi:BPMNShape>\n      <bpmndi:BPMNEdge id=\"SequenceFlow_0ociprs_di\" bpmnElement=\"SequenceFlow_0ociprs\">\n        <di:waypoint x=\"215\" y=\"117\"/>\n        <di:waypoint x=\"300\" y=\"117\"/>\n      </bpmndi:BPMNEdge>\n      <bpmndi:BPMNEdge id=\"SequenceFlow_0jg4sg3_di\" bpmnElement=\"SequenceFlow_0jg4sg3\">\n        <di:waypoint x=\"400\" y=\"117\"/>\n        <di:waypoint x=\"505\" y=\"117\"/>\n      </bpmndi:BPMNEdge>\n      <bpmndi:BPMNEdge id=\"SequenceFlow_1x38yu4_di\" bpmnElement=\"SequenceFlow_1x38yu4\">\n        <di:waypoint x=\"555\" y=\"117\"/>\n        <di:waypoint x=\"660\" y=\"117\"/>\n        <bpmndi:BPMNLabel>\n          <dc:Bounds x=\"587\" y=\"99\" width=\"41\" height=\"14\"/>\n        </bpmndi:BPMNLabel>\n      </bpmndi:BPMNEdge>\n      <bpmndi:BPMNEdge id=\"SequenceFlow_0pc6hcp_di\" bpmnElement=\"SequenceFlow_0pc6hcp\">\n        <di:waypoint x=\"530\" y=\"142\"/>\n        <di:waypoint x=\"530\" y=\"167\"/>\n        <di:waypoint x=\"660\" y=\"167\"/>\n        <bpmndi:BPMNLabel>\n          <dc:Bounds x=\"579\" y=\"150\" width=\"28\" height=\"14\"/>\n        </bpmndi:BPMNLabel>\n      </bpmndi:BPMNEdge>\n      <bpmndi:BPMNEdge id=\"SequenceFlow_00bn1p7_di\" bpmnElement=\"SequenceFlow_00bn1p7\">\n        <di:waypoint x=\"760\" y=\"137\"/>\n        <di:waypoint x=\"790\" y=\"137\"/>\n      </bpmndi:BPMNEdge>\n      <bpmndi:BPMNEdge id=\"Flow_1cbkpva_di\" bpmnElement=\"Flow_1cbkpva\">\n        <di:waypoint x=\"890\" y=\"137\"/>\n        <di:waypoint x=\"922\" y=\"137\"/>\n      </bpmndi:BPMNEdge>\n    </bpmndi:BPMNPlane>\n  </bpmndi:BPMNDiagram>\n</bpmn:definitions>\n"
