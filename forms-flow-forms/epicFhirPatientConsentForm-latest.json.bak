          {
            "label": "surrogateKey",
            "customClass": "",
            "modalEdit": false,
            "defaultValue": null,
            "persistent": true,
            "protected": false,
            "dbIndex": false,
            "encrypted": false,
            "redrawOn": "",
            "customDefaultValue": "// Formio hidden field 'surrogateKey' custom default value\nvalue = 'xxxxxxxx-xxxx-4xxx-yxxx-xxxxxxxxxxxx'.replace(/[xy]/g, function(c) {\n  var r = Math.random() * 16 | 0, v = c == 'x' ? r : (r & 0x3 | 0x8);\n  return v.toString(16);\n});",
            "calculateValue": "value || (function() {  var s = [];  var hex = '0123456789abcdef';  for (var i = 0; i < 36; i++) { s[i] = hex[Math.floor(Math.random() * 16)]; }  s[14] = '4';  s[19] = hex[(s[19] & 0x3) | 0x8];  s[8] = s[13] = s[18] = s[23] = '-';  return s.join('');})()",
            "calculateServer": false,
            "key": "surrogateKey",
